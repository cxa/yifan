# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'yifan' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )


  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = min_ios_version_supported
      end
    end
    # Add a Run Script build phase to the app target that fixes missing MinimumOSVersion in
    # embedded prebuilt frameworks (e.g. hermesvm.framework) at build time, inside the .app bundle.
    # This is more robust than patching Pods files, which can be overwritten by subsequent builds.
    require 'xcodeproj'
    app_project_path = File.join(installer.sandbox.root, '..', 'yifan.xcodeproj')
    app_project = Xcodeproj::Project.open(app_project_path)
    app_project.targets.each do |target|
      next unless target.name == 'yifan'
      phase_name = 'Fix MinimumOSVersion in Embedded Frameworks'
      next if target.shell_script_build_phases.any? { |p| p.name == phase_name }
      phase = target.new_shell_script_build_phase(phase_name)
      phase.shell_script = <<~'SHELL'
        find "${CODESIGNING_FOLDER_PATH}/Frameworks" -name "Info.plist" | while read plist; do
          val=$(/usr/libexec/PlistBuddy -c "Print :MinimumOSVersion" "$plist" 2>/dev/null)
          if [ -z "$val" ]; then
            /usr/libexec/PlistBuddy -c "Add :MinimumOSVersion string ${IPHONEOS_DEPLOYMENT_TARGET}" "$plist"
          fi
        done
      SHELL
    end
    app_project.save
  end
end
