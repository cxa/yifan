# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# Bumped from RN's `min_ios_version_supported` (15.1) so that pods like
# GoogleMLKit/FaceDetection (requires iOS 15.5+) can install. App target is
# already 16.0 in the Xcode project, so this doesn't shut out any device
# we weren't already excluding.
APP_IOS_TARGET = '16.0'
platform :ios, APP_IOS_TARGET
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'yifan' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )


  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = APP_IOS_TARGET
      end
    end
    # Patch MinimumOSVersion into prebuilt framework Info.plists (e.g. hermesvm.framework)
    # directly in the Pods directory, before Xcode embeds and signs them.
    # A post-build Run Script approach would modify already-signed frameworks and break codesign.
    min_os = APP_IOS_TARGET.to_s
    Dir.glob(File.join(installer.sandbox.root, '**/*.framework/Info.plist')) do |plist|
      existing = `/usr/libexec/PlistBuddy -c "Print :MinimumOSVersion" "#{plist}" 2>/dev/null`.strip
      if existing.empty?
        system("/usr/libexec/PlistBuddy -c 'Add :MinimumOSVersion string #{min_os}' '#{plist}'")
      end
    end
  end
end
